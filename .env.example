# Server
PORT=3001
ENVIRONMENT=development
# Set TRUST_PROXY=true only when running behind a reverse proxy that appends
# the client IP to X-Forwarded-For; the rate limiter then uses its rightmost
# entry instead of the socket address.
# TRUST_PROXY=true

# Database (local Postgres, no password)
DB_HOSTNAME=127.0.0.1
DB_PORT=5432
DB_USER=skylerberg
DB_DATABASE=game_dev
# DB_PASSWORD=
# DB_CA_CERT_PATH=

# Storage
STORAGE_DRIVER=disk
STORAGE_DISK_ROOT=./data/uploads

# Auth
SESSION_TTL_DAYS=30
# SIGNUP_ENABLED defaults to true in development/test, false in production
# SIGNUP_ENABLED=true

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173

# LOG_FORMAT=pretty

# Password reset (required in production; development uses a fixed dev-only secret)
# PASSWORD_RESET_SECRET=
# RESET_URL_BASE=http://localhost:5173/reset-password

# Email (console logs the full email; ses sends via AWS SES v2)
EMAIL_DRIVER=console
# SES_REGION=us-west-2
# SES_FROM_ADDRESS=no-reply@example.com
