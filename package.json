{
  "name": "critical-path-api",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "node --env-file=.env --import tsx --watch src/index.ts",
    "start": "node --env-file=.env --import tsx src/index.ts",
    "build": "tsc",
    "build:prod": "esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.mjs --packages=external",
    "type-check": "tsc --noEmit",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "migrate": "node --env-file=.env --import tsx src/db/migrate.ts",
    "migrate:down": "node --env-file=.env --import tsx src/db/migrate.ts down",
    "migrate:test": "node --env-file=.env.test --import tsx src/db/migrate.ts",
    "kysely-codegen": "kysely-codegen --dialect postgres --out-file ./src/db/types.ts",
    "openapi:dump": "node --env-file=.env --import tsx scripts/dump-openapi.ts",
    "test": "node --env-file=.env.test node_modules/vitest/vitest.mjs run",
    "test:watch": "node --env-file=.env.test node_modules/vitest/vitest.mjs",
    "test:coverage": "node --env-file=.env.test node_modules/vitest/vitest.mjs run --coverage",
    "prepare": "node scripts/setup-hooks.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-sesv2": "^3.1082.0",
    "@google-cloud/storage": "^7.21.0",
    "@hono/node-server": "^2.0.8",
    "@hono/standard-validator": "0.2.3",
    "@hono/swagger-ui": "~0.6.1",
    "@standard-community/standard-json": "^0.3.5",
    "@standard-community/standard-openapi": "~0.2.9",
    "argon2": "~0.44.0",
    "arktype": "2.2.3",
    "hono": "~4.12.28",
    "hono-openapi": "1.3.1",
    "kysely": "~0.29.3",
    "openapi-types": "^12.1.3",
    "pg": "~8.22.0",
    "redis": "^6.1.0",
    "tsx": "^4.23.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@standard-schema/spec": "^1.1.0",
    "@types/json-schema": "^7.0.15",
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "~4.1.10",
    "esbuild": "^0.28.1",
    "eslint": "^10.6.0",
    "kysely-codegen": "~0.20.0",
    "prettier": "~3.8.5",
    "typescript": "6.0.3",
    "typescript-eslint": "~8.63.0",
    "vitest": "~4.1.10"
  },
  "engines": {
    "node": ">=22"
  }
}
