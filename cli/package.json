{
  "name": "critical-path-cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "cpath": "bin/cpath.mjs"
  },
  "scripts": {
    "generate-api": "node scripts/generate-api-types.mjs && prettier --write src/api/api.generated.ts",
    "type-check": "tsc -p tsconfig.json",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\" \"bin/*.mjs\" \"scripts/*.mjs\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\" \"bin/*.mjs\" \"scripts/*.mjs\"",
    "check": "npm run type-check && npm run lint && npm run format:check"
  },
  "dependencies": {
    "commander": "15.0.0",
    "mdast-util-from-markdown": "2.0.3",
    "mdast-util-gfm-strikethrough": "2.0.0",
    "mdast-util-to-markdown": "2.1.2",
    "micromark-extension-gfm-strikethrough": "2.1.0",
    "openapi-fetch": "0.17.0",
    "tsx": "4.23.1"
  },
  "devDependencies": {
    "@types/mdast": "4.0.4",
    "openapi-typescript": "7.13.0"
  },
  "engines": {
    "node": ">=22"
  },
  "overrides": {
    "js-yaml": "4.3.0"
  }
}
